    {
      "name": "RetrieveBooking (Before)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code: 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const b = pm.response.json();",
              "",
              "//compared if the booking info of this booking is the same as the one created",
              "pm.test(\"Booking fields match created data\", () => {",
              "  pm.expect(b.firstname).to.eql(pm.environment.get(\"bookingFirstName\")); ",
              "  pm.expect(b.lastname).to.eql(pm.environment.get(\"bookingLastName\"));",
              "  pm.expect(b.totalprice).to.eql(Number(pm.environment.get(\"bookingPrice\")));",
              "});"
