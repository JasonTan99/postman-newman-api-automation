    {
      "name": "Update Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"StatusCode: 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const b = pm.response.json();",
              "//print in Test Results whether update successful",
              "pm.test(\"Booking details updated\", () => {",
              "  pm.expect(b.lastname).to.eql(\"Tan\");",
              "  pm.expect(b.totalprice).to.eql(Number(\"999\"));",
              "});",
              "",
              "//Assign back latest value, so that when call RetrieveBooking will return latest details",
              "pm.environment.set(\"bookingLastName\", b.lastname);",
              "pm.environment.set(\"bookingPrice\", b.totalprice);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
