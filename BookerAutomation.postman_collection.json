  "item": [
    {
      "name": "Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Auth returns 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json(); //convert response JSON into a JS object called body",
              "pm.test(\"Token exists\", () => {",
              "  pm.expect(body.token).to.be.a(\"string\");",
              "  pm.expect(body.token.length).to.be.above(5);",
              "});",
              "",
              "pm.environment.set(\"token\", body.token); //save variable"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth"
          ]
        },
        "description": "This is a POST request, submitting data to an API via the request body. This request submits JSON data, and the data is reflected in the response.\n\nA successful POST request typically returns a `200 OK` or `201 Created` response code."
      },
      "response": []
    },
    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code: 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(`BookingID ${body.bookingid}`, () => {",
              "  pm.expect(body.bookingid).to.be.a(\"number\");",
              "});",
              "",
              "// save bookingId for next request",
              "pm.environment.set(\"bookingId\", body.bookingid);",
              "console.log(body.bookingid);",
              "// optional: also save expected values to compare later",
              "pm.environment.set(\"bookingFirstName\", body.booking.firstname);",
              "pm.environment.set(\"bookingLastName\", body.booking.lastname);",
              "pm.environment.set(\"bookingPrice\", body.booking.totalprice);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
