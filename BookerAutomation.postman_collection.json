        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Jason\",\n  \"lastname\": \"Zai\",\n  \"totalprice\": 123,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-02-27\",\n    \"checkout\": \"2026-02-28\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}",
          "options": {
            "raw": {
              "language": "json"
